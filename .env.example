# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — NEVER commit real secrets.
# All values below are PLACEHOLDERS — replace before running.

# ─── Lead source ──────────────────────────────────────────────
# Google Places API (https://console.cloud.google.com)
# Enable: Places API (New) → Credentials → Create API key
GOOGLE_PLACES_API_KEY=YOUR_GOOGLE_PLACES_KEY

# ─── AI providers ─────────────────────────────────────────────
# Email/DM generation — Groq (https://console.groq.com)
GROQ_API_KEY=gsk_YOUR_GROQ_KEY

# AI sales assistant — Gemini (https://aistudio.google.com/apikey)
# Use the AIza-prefix key from a NEW PROJECT for free-tier quota
GEMINI_API_KEY=AIzaYOUR_GEMINI_KEY

# Optional fallback (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_KEY

# ─── Auth (Clerk) ─────────────────────────────────────────────
# Get from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_CLERK_PUBLISHABLE
CLERK_SECRET_KEY=sk_test_YOUR_CLERK_SECRET
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/app

# ─── Payments (Razorpay) ──────────────────────────────────────
# Get from https://dashboard.razorpay.com → Account & Settings → API Keys
# Use rzp_test_* in dev, rzp_live_* in production (KYC required for live)
RAZORPAY_KEY_ID=rzp_test_YOUR_RAZORPAY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_SECRET

# ─── App config ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk user_xxx id of the admin user (sees /admin page)
ADMIN_USER_ID=user_YOUR_CLERK_USER_ID
